<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, maximum-scale=1.0">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#1a0a33">
    <title>TOKYO STEEL - Mobile Ready</title>
    <style>
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            -webkit-tap-highlight-color: transparent;
        }
        
        html, body { 
            width: 100%; 
            height: 100%; 
            overflow: hidden; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #1a0a33;
            touch-action: none;
        }
        
        #gameCanvas { 
            width: 100%; 
            height: 100%; 
            display: block; 
            position: absolute;
            top: 0;
            left: 0;
            z-index: 1;
        }
        
        /* HUD - Responsive */
        #hud {
            position: fixed;
            top: 10px;
            left: 10px;
            color: white;
            z-index: 100;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
            font-size: 14px;
            line-height: 1.5;
        }
        
        .hud-item {
            background: linear-gradient(135deg, rgba(50,30,100,0.85), rgba(30,10,60,0.75));
            padding: 8px 12px;
            border-radius: 4px;
            border-left: 3px solid #6d4aff;
            margin-bottom: 6px;
            font-size: 12px;
        }
        
        @media (max-width: 768px) {
            #hud {
                font-size: 11px;
                top: 5px;
                left: 5px;
            }
            .hud-item {
                padding: 5px 8px;
                margin-bottom: 4px;
            }
        }
        
        /* Crosshair */
        #crosshair {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 100;
            pointer-events: none;
        }
        
        .crosshair-center {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 4px;
            height: 4px;
            background: #6d4aff;
            border-radius: 50%;
        }
        
        .crosshair-lines {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 20px;
            height: 20px;
        }
        
        .crosshair-lines::before, .crosshair-lines::after {
            content: '';
            position: absolute;
            background: rgba(109, 75, 255, 0.6);
        }
        
        .crosshair-lines::before {
            width: 2px;
            height: 20px;
            left: 50%;
            transform: translateX(-50%);
        }
        
        .crosshair-lines::after {
            width: 20px;
            height: 2px;
            top: 50%;
            transform: translateY(-50%);
        }
        
        /* Instructions */
        #instructions {
            position: fixed;
            bottom: 10px;
            left: 50%;
            transform: translateX(-50%);
            color: white;
            background: rgba(50,30,100,0.85);
            padding: 10px 20px;
            border-radius: 6px;
            text-align: center;
            z-index: 100;
            font-size: 12px;
            border: 1px solid #6d4aff;
            display: none;
        }
        
        @media (max-width: 768px) {
            #instructions {
                display: none !important;
            }
        }
        
        /* Start Screen */
        #startScreen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(rgba(30,10,60,0.98), rgba(50,30,100,0.98));
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            z-index: 200;
            color: white;
        }
        
        #startScreen h1 {
            font-size: 48px;
            margin-bottom: 15px;
            text-shadow: 0 0 30px #6d4aff;
            letter-spacing: 5px;
            text-align: center;
        }
        
        @media (max-width: 768px) {
            #startScreen h1 {
                font-size: 32px;
            }
        }
        
        #startScreen p {
            font-size: 16px;
            margin-bottom: 30px;
            opacity: 0.9;
            text-align: center;
        }
        
        #startButton {
            background: linear-gradient(135deg, #6d4aff, #8f6dff);
            border: none;
            color: white;
            padding: 15px 40px;
            font-size: 18px;
            cursor: pointer;
            border-radius: 8px;
            transition: all 0.3s;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(109, 75, 255, 0.5);
        }
        
        #startButton:hover {
            transform: scale(1.05);
            box-shadow: 0 0 40px #6d4aff;
        }
        
        #startButton:active {
            transform: scale(0.98);
        }
        
        /* Reload Indicator */
        #reloadIndicator {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #ff4444;
            font-size: 20px;
            font-weight: bold;
            z-index: 150;
            text-shadow: 0 0 10px rgba(0,0,0,0.8);
            display: none;
            pointer-events: none;
        }
        
        /* Damage Overlay */
        #damageOverlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(ellipse at center, transparent 0%, rgba(255,0,0,0.3) 100%);
            pointer-events: none;
            z-index: 90;
            opacity: 0;
            transition: opacity 0.2s;
        }
        
        .rank-display {
            font-size: 14px;
            color: #ffd700;
        }
        
        /* ========== MOBILE CONTROLS ========== */
        .mobile-controls {
            position: fixed;
            display: none;
            pointer-events: none;
            z-index: 100;
        }
        
        @media (max-width: 768px) {
            .mobile-controls {
                display: block;
            }
        }
        
        /* Virtual Joystick Zone */
        #joystickZone {
            position: fixed;
            bottom: 80px;
            left: 50px;
            width: 120px;
            height: 120px;
            z-index: 95;
            pointer-events: auto;
        }
        
        .joystick-base {
            position: absolute;
            width: 100%;
            height: 100%;
            background: rgba(109, 75, 255, 0.2);
            border: 2px solid rgba(109, 75, 255, 0.4);
            border-radius: 50%;
        }
        
        .joystick-stick {
            position: absolute;
            width: 50px;
            height: 50px;
            background: rgba(109, 75, 255, 0.6);
            border-radius: 50%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            transition: transform 0.05s;
        }
        
        /* Touch Look Zone */
        #touchLookZone {
            position: fixed;
            top: 0;
            right: 0;
            width: 50%;
            height: 100%;
            z-index: 94;
            pointer-events: auto;
            /* Debug visual - uncomment to see */
            /* background: rgba(0, 255, 0, 0.1); */
        }
        
        /* Action Buttons */
        .action-button {
            position: fixed;
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background: rgba(109, 75, 255, 0.6);
            border: 3px solid rgba(109, 75, 255, 0.9);
            color: white;
            font-size: 24px;
            font-weight: bold;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 96;
            pointer-events: auto;
            user-select: none;
            -webkit-user-select: none;
        }
        
        .action-button:active {
            background: rgba(109, 75, 255, 0.9);
            transform: scale(0.95);
        }
        
        /* Position buttons for mobile */
        #fireButton {
            bottom: 80px;
            right: 40px;
        }
        
        #jumpButton {
            bottom: 80px;
            left: 40px;
            background: rgba(0, 200, 100, 0.6);
            border-color: rgba(0, 200, 100, 0.9);
        }
        
        #reloadButton {
            top: 80px;
            right: 40px;
            background: rgba(255, 150, 0, 0.6);
            border-color: rgba(255, 150, 0, 0.9);
        }
        
        /* Button labels */
        .action-label {
            position: absolute;
            bottom: -20px;
            font-size: 10px;
            color: white;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
        }
        
        /* Paused Screen */
        #pauseScreen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(30,10,60,0.95);
            display: none;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            z-index: 300;
            color: white;
        }
        
        #pauseScreen h2 {
            font-size: 36px;
            margin-bottom: 30px;
        }
        
        #resumeButton {
            background: linear-gradient(135deg, #6d4aff, #8f6dff);
            border: none;
            color: white;
            padding: 15px 40px;
            font-size: 18px;
            cursor: pointer;
            border-radius: 8px;
            margin-bottom: 15px;
        }
        
        #quitButton {
            background: transparent;
            border: 2px solid #ff4444;
            color: #ff4444;
            padding: 12px 35px;
            font-size: 16px;
            cursor: pointer;
            border-radius: 8px;
        }
    </style>
</head>
<body>
    <!-- Damage Overlay -->
    <div id="damageOverlay"></div>

    <!-- Start Screen -->
    <div id="startScreen">
        <h1>🥷 TOKYO STEEL</h1>
        <p>Mobile Ready - Walk the streets. Master the way.</p>
        <button id="startButton">ENTER THE DOJO</button>
        <p style="font-size: 12px; margin-top: 20px;">
            Desktop: WASD + Mouse<br>
            Mobile: Joystick + Touch
        </p>
    </div>

    <!-- Pause Screen -->
    <div id="pauseScreen">
        <h2>PAUSED</h2>
        <button id="resumeButton">RESUME</button>
        <button id="quitButton">QUIT TO MENU</button>
    </div>

    <!-- HUD -->
    <div id="hud">
        <div class="hud-item rank-display">RANK: 10th Kyu</div>
        <div class="hud-item">SCORE: <span id="score">0</span></div>
        <div class="hud-item">HEALTH: <span id="health">100</span></div>
        <div class="hud-item">AMMO: <span id="ammo">30</span>/<span id="maxAmmo">30</span></div>
        <div class="hud-item">COMBO: <span id="combo">x1</span></div>
    </div>

    <!-- Crosshair -->
    <div id="crosshair">
        <div class="crosshair-center"></div>
        <div class="crosshair-lines"></div>
    </div>

    <!-- Reload Indicator -->
    <div id="reloadIndicator">PRESS R / TAP RELOAD</div>

    <!-- Instructions (Desktop only) -->
    <div id="instructions">
        WASD = Move | SHIFT = Sprint | MOUSE = Aim | CLICK = Throw | SPACE = Jump | R = Reload
    </div>

    <!-- Game Canvas -->
    <canvas id="gameCanvas"></canvas>

    <!-- ========== MOBILE CONTROLS ========== -->
    <div class="mobile-controls">
        <!-- Virtual Joystick -->
        <div id="joystickZone">
            <div class="joystick-base"></div>
            <div class="joystick-stick" id="joystickStick"></div>
        </div>
        
        <!-- Touch Look Zone (covers right half of screen) -->
        <div id="touchLookZone"></div>
        
        <!-- Action Buttons -->
        <div class="action-button" id="fireButton">
            🔥
            <span class="action-label">FIRE</span>
        </div>
        
        <div class="action-button" id="jumpButton">
            ⬆
            <span class="action-label">JUMP</span>
        </div>
        
        <div class="action-button" id="reloadButton">
            ⟳
            <span class="action-label">RELOAD</span>
        </div>
    </div>

    <!-- Three.js CDN -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <!-- Audio System -->
    <script>
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        
        function playThrowSound() {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.frequency.setValueAtTime(800, audioCtx.currentTime);
            osc.frequency.exponentialRampToValueAtTime(200, audioCtx.currentTime + 0.1);
            gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);
            osc.start(audioCtx.currentTime);
            osc.stop(audioCtx.currentTime + 0.1);
        }
        
        function playHitSound() {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.type = 'square';
            osc.frequency.setValueAtTime(200, audioCtx.currentTime);
            osc.frequency.exponentialRampToValueAtTime(50, audioCtx.currentTime + 0.05);
            gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.05);
            osc.start(audioCtx.currentTime);
            osc.stop(audioCtx.currentTime + 0.05);
        }
        
        function playEnemyAttackSound() {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.type = 'sawtooth';
            osc.frequency.setValueAtTime(150, audioCtx.currentTime);
            osc.frequency.linearRampToValueAtTime(100, audioCtx.currentTime + 0.15);
            gain.gain.setValueAtTime(0.25, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.15);
            osc.start(audioCtx.currentTime);
            osc.stop(audioCtx.currentTime + 0.15);
        }
        
        function playReloadSound() {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.frequency.setValueAtTime(400, audioCtx.currentTime);
            osc.frequency.linearRampToValueAtTime(600, audioCtx.currentTime + 0.2);
            gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
            gain.gain.linearRampToValueAtTime(0.01, audioCtx.currentTime + 0.2);
            osc.start(audioCtx.currentTime);
            osc.stop(audioCtx.currentTime + 0.2);
        }
    </script>

    <script>
        // ============================================
        // TOKYO STEEL — MOBILE READY EDITION
        // ============================================
        
        // Device detection
        const isMobile = /Android|iPhone|iPad|iPod/i.test(navigator.userAgent) || window.innerWidth < 768;
        console.log('Device:', isMobile ? 'Mobile' : 'Desktop');
        
        let scene, camera, renderer;
        let player = {
            x: 0, y: 1.7, z: 10,
            velocityY: 0,
            speed: 5,
            sprintSpeed: 9,
            jumping: false,
            health: 100,
            score: 0,
            maxAmmo: 30,
            ammo: 30,
            combo: 1,
            reloading: false
        };
        
        let keys = {};
        let enemies = [];
        let projectiles = [];
        let bonuses = [];
        let lastThrow = 0;
        let throwCooldown = 400;
        let lastReload = 0;
        let reloadDuration = 1000;
        
        // Mobile controls state
        let joystick = { active: false, dx: 0, dy: 0, startX: 0, startY: 0 };
        let touchLook = { active: false, lastX: 0, lastY: 0 };
        let isPaused = false;
        
        const clock = new THREE.Clock();
        
        // Audio resume on interaction
        function resumeAudio() {
            if (audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
        }
        
        // Initialize
        function init() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x1a0a33);
            scene.fog = new THREE.Fog(0x1a0a33, 20, 100);
            
            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(player.x, player.y, player.z);
            
            renderer = new THREE.WebGLRenderer({ 
                canvas: document.getElementById('gameCanvas'),
                antialias: !isMobile // Disable AA on mobile for performance
            });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            
            // Lighting
            const ambientLight = new THREE.AmbientLight(0x404060, 0.6);
            scene.add(ambientLight);
            
            const moonLight = new THREE.DirectionalLight(0x8f6dff, 0.8);
            moonLight.position.set(50, 100, 50);
            moonLight.castShadow = true;
            scene.add(moonLight);
            
            buildStreet();
            spawnEnemies(8);
            spawnBonuses(3);
            
            // Setup controls
            setupControls();
            
            // Start screen
            document.getElementById('startButton').addEventListener('click', () => {
                resumeAudio();
                startGame();
            });
            
            // Pause buttons
            document.getElementById('resumeButton').addEventListener('click', () => {
                isPaused = false;
                document.getElementById('pauseScreen').style.display = 'none';
            });
            
            document.getElementById('quitButton').addEventListener('click', () => {
                location.reload();
            });
            
            animate();
        }
        
        function startGame() {
            document.getElementById('startScreen').style.display = 'none';
            
            if (!isMobile) {
                // Desktop - use pointer lock
                document.body.requestPointerLock();
                document.getElementById('instructions').style.display = 'block';
            } else {
                // Mobile - already have touch controls visible
                showMobileInstructions();
            }
        }
        
        function showMobileInstructions() {
            // Brief instruction overlay for first-time mobile players
            const instr = document.createElement('div');
            instr.style.cssText = `
                position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
                background:rgba(30,10,60,0.95);color:white;padding:20px;text-align:center;
                border-radius:10px;z-index:250;font-size:14px;border:2px solid #6d4aff;
            `;
            instr.innerHTML = `
                <h3 style="margin-bottom:15px;color:#6d4aff;">MOBILE CONTROLS</h3>
                <p>Left joystick = Move</p>
                <p>Drag right side = Look</p>
                <p>Fire button = Throw</p>
                <br>
                <button onclick="this.parentElement.remove()" style="padding:10px 30px;background:#6d4aff;border:none;color:white;border-radius:5px;">UNDERSTOOD</button>
            `;
            document.body.appendChild(instr);
        }
        
        function buildStreet() {
            // Ground
            const groundGeo = new THREE.PlaneGeometry(40, 200);
            const groundMat = new THREE.MeshStandardMaterial({ color: 0x2a2a40, roughness: 0.8 });
            const ground = new THREE.Mesh(groundGeo, groundMat);
            ground.rotation.x = -Math.PI / 2;
            ground.position.z = -50;
            ground.receiveShadow = true;
            scene.add(ground);
            
            // Buildings (simplified for mobile)
            for (let i = 0; i < 8; i++) {
                const bw = 4 + Math.random() * 3;
                const bh = 8 + Math.random() * 15;
                
                const bGeo = new THREE.BoxGeometry(bw, bh, 8);
                const bMat = new THREE.MeshStandardMaterial({ 
                    color: new THREE.Color().setHSL(Math.random() * 0.1 + 0.55, 0.6, 0.3),
                    emissive: new THREE.Color().setHSL(Math.random() * 0.1 + 0.55, 0.8, 0.5),
                    emissiveIntensity: 0.4
                });
                
                const building = new THREE.Mesh(bGeo, bMat);
                building.position.set(-(bw/2 + 2), bh/2, -i * 20);
                building.castShadow = true;
                scene.add(building);
                
                // Neon signs
                createNeonSign(building.position.x, building.position.y + 5, building.position.z, bMat.color);
            }
            
            for (let i = 0; i < 8; i++) {
                const bw = 4 + Math.random() * 3;
                const bh = 8 + Math.random() * 15;
                
                const bGeo = new THREE.BoxGeometry(bw, bh, 8);
                const bMat = new THREE.MeshStandardMaterial({ 
                    color: new THREE.Color().setHSL(Math.random() * 0.1 + 0.05, 0.7, 0.35),
                    emissive: new THREE.Color().setHSL(Math.random() * 0.1 + 0.05, 0.8, 0.5),
                    emissiveIntensity: 0.4
                });
                
                const building = new THREE.Mesh(bGeo, bMat);
                building.position.set(bw/2 + 2, bh/2, -i * 20);
                building.castShadow = true;
                scene.add(building);
                
                createNeonSign(building.position.x, building.position.y + 5, building.position.z, bMat.color);
            }
            
            // Lanterns
            for (let i = 0; i < 10; i++) {
                const lantern = new THREE.Mesh(
                    new THREE.SphereGeometry(0.3, 8, 8),
                    new THREE.MeshBasicMaterial({ color: 0xff6600, transparent: true, opacity: 0.8 })
                );
                lantern.position.set((i % 2 === 0 ? 6 : -6), 3, -i * 10 - 5);
                scene.add(lantern);
                
                const light = new THREE.PointLight(0xff6600, 1, 8);
                light.position.copy(lantern.position);
                scene.add(light);
            }
        }
        
        function createNeonSign(x, y, z, color) {
            const sign = new THREE.Mesh(
                new THREE.BoxGeometry(1.5, 0.3, 3),
                new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0.8 })
            );
            sign.position.set(x, y, z);
            scene.add(sign);
            
            const glow = new THREE.PointLight(color, 0.5, 10);
            glow.position.set(x, y - 0.5, z);
            scene.add(glow);
        }
        
        function createShurikenModel() {
            const group = new THREE.Group();
            
            // Hub
            const hub = new THREE.Mesh(
                new THREE.CylinderGeometry(0.05, 0.05, 0.02, 8),
                new THREE.MeshStandardMaterial({ color: 0xcccccc, metalness: 0.8, roughness: 0.2 })
            );
            hub.rotation.x = Math.PI / 2;
            group.add(hub);
            
            // Points
            const pointGeo = new THREE.ConeGeometry(0.08, 0.3, 4);
            const pointMat = new THREE.MeshStandardMaterial({ color: 0xaaaaaa, metalness: 0.9, roughness: 0.1 });
            
            for (let i = 0; i < 4; i++) {
                const point = new THREE.Mesh(pointGeo, pointMat);
                point.position.y = 0.15;
                point.rotation.x = Math.PI / 2;
                point.rotation.z = (i * Math.PI) / 2;
                group.add(point);
            }
            
            return group;
        }
        
        function spawnEnemies(count) {
            for (let i = 0; i < count; i++) {
                const enemy = new THREE.Mesh(
                    new THREE.CapsuleGeometry(0.5, 1.8, 4, 8),
                    new THREE.MeshStandardMaterial({ color: new THREE.Color().setHSL(0 + Math.random() * 0.1, 0.7, 0.5) })
                );
                
                enemy.position.set((Math.random() - 0.5) * 10, 1.4, -15 - Math.random() * 50);
                enemy.castShadow = true;
                
                enemy.userData = {
                    health: 50,
                    maxHealth: 50,
                    speed: 1 + Math.random() * 1.5,
                    lastAttack: 0,
                    healthBar: null
                };
                
                // Health bar
                const barContainer = new THREE.Mesh(new THREE.BoxGeometry(1.2, 0.15, 0.1), new THREE.MeshBasicMaterial({ color: 0x333333 }));
                barContainer.position.set(enemy.position.x, 2.7, enemy.position.z);
                scene.add(barContainer);
                
                const healthFill = new THREE.Mesh(new THREE.BoxGeometry(1.0, 0.1, 0.11), new THREE.MeshBasicMaterial({ color: 0xff3333 }));
                healthFill.position.set(enemy.position.x, 2.7, enemy.position.z);
                scene.add(healthFill);
                
                enemy.userData.healthBar = { container: barContainer, fill: healthFill };
                scene.add(enemy);
                enemies.push(enemy);
            }
        }
        
        function spawnBonuses(count) {
            for (let i = 0; i < count; i++) {
                const bonus = new THREE.Mesh(
                    new THREE.OctahedronGeometry(0.4),
                    new THREE.MeshBasicMaterial({ color: 0x00ff88, transparent: true, opacity: 0.9 })
                );
                
                bonus.position.set((Math.random() - 0.5) * 12, 1, -10 - Math.random() * 40);
                bonus.userData = { type: ['damage', 'speed', 'health'][Math.floor(Math.random() * 3)], rotationSpeed: 2 + Math.random() * 2 };
                scene.add(bonus);
                bonuses.push(bonus);
            }
        }
        
        // ========== CONTROL SETUP ==========
        function setupControls() {
            if (!isMobile) {
                setupDesktopControls();
            } else {
                setupMobileControls();
            }
        }
        
        function setupDesktopControls() {
            document.addEventListener('keydown', (e) => { keys[e.code] = true; if (e.code === 'KeyR') reloadWeapons(); });
            document.addEventListener('keyup', (e) => { keys[e.code] = false; });
            document.addEventListener('mousedown', (e) => { if (document.pointerLockElement === document.body) throwProjectile(); });
            document.addEventListener('mousemove', (e) => {
                if (document.pointerLockElement !== document.body) return;
                camera.rotation.y -= e.movementX * 0.002;
                camera.rotation.x -= e.movementY * 0.002;
                camera.rotation.x = Math.max(-Math.PI/2, Math.min(Math.PI/2, camera.rotation.x));
            });
            document.addEventListener('pointerlockchange', () => {
                if (document.pointerLockElement !== document.body && !isPaused) {
                    // Auto-pause when mouse unlocked
                    // isPaused = true;
                    // document.getElementById('pauseScreen').style.display = 'flex';
                }
            });
        }
        
        function setupMobileControls() {
            // Joystick
            const joyZone = document.getElementById('joystickZone');
            const joyStick = document.getElementById('joystickStick');
            
            joyZone.addEventListener('touchstart', (e) => {
                e.preventDefault();
                const touch = e.changedTouches[0];
                joystick.active = true;
                joystick.startX = touch.clientX;
                joystick.startY = touch.clientY;
                joystick.dx = 0;
                joystick.dy = 0;
            }, { passive: false });
            
            joyZone.addEventListener('touchmove', (e) => {
                e.preventDefault();
                if (!joystick.active) return;
                
                const touch = e.changedTouches[0];
                const dx = touch.clientX - joystick.startX;
                const dy = touch.clientY - joystick.startY;
                const dist = Math.sqrt(dx * dx + dy * dy);
                const maxDist = 35;
                
                const clampedDist = Math.min(dist, maxDist);
                const angle = Math.atan2(dy, dx);
                
                joystick.dx = (clampedDist / maxDist) * Math.cos(angle);
                joystick.dy = (clampedDist / maxDist) * Math.sin(angle);
                
                joyStick.style.transform = `translate(calc(-50% + ${joystick.dx * 35}px), calc(-50% + ${joystick.dy * 35}px))`;
            }, { passive: false });
            
            joyZone.addEventListener('touchend', (e) => {
                e.preventDefault();
                joystick.active = false;
                joystick.dx = 0;
                joystick.dy = 0;
                joyStick.style.transform = 'translate(-50%, -50%)';
            }, { passive: false });
            
            // Touch look zone
            const lookZone = document.getElementById('touchLookZone');
            
            lookZone.addEventListener('touchstart', (e) => {
                e.preventDefault();
                const touch = e.changedTouches[0];
                touchLook.active = true;
                touchLook.lastX = touch.clientX;
                touchLook.lastY = touch.clientY;
            }, { passive: false });
            
            lookZone.addEventListener('touchmove', (e) => {
                e.preventDefault();
                if (!touchLook.active) return;
                
                const touch = e.changedTouches[0];
                const dx = touch.clientX - touchLook.lastX;
                const dy = touch.clientY - touchLook.lastY;
                
                camera.rotation.y -= dx * 0.004;
                camera.rotation.x -= dy * 0.004;
                camera.rotation.x = Math.max(-Math.PI/2, Math.min(Math.PI/2, camera.rotation.x));
                
                touchLook.lastX = touch.clientX;
                touchLook.lastY = touch.clientY;
            }, { passive: false });
            
            lookZone.addEventListener('touchend', (e) => {
                e.preventDefault();
                touchLook.active = false;
            }, { passive: false });
            
            // Fire button
            document.getElementById('fireButton').addEventListener('touchstart', (e) => {
                e.preventDefault();
                resumeAudio();
                throwProjectile();
            }, { passive: false });
            
            // Jump button
            document.getElementById('jumpButton').addEventListener('touchstart', (e) => {
                e.preventDefault();
                resumeAudio();
                if (!player.jumping) {
                    player.velocityY = 8;
                    player.jumping = true;
                }
            }, { passive: false });
            
            // Reload button
            document.getElementById('reloadButton').addEventListener('touchstart', (e) => {
                e.preventDefault();
                resumeAudio();
                reloadWeapons();
            }, { passive: false });
        }
        
        function reloadWeapons() {
            const now = Date.now();
            if (now - lastReload < reloadDuration || player.ammo >= player.maxAmmo || player.reloading) return;
            
            player.reloading = true;
            lastReload = now;
            playReloadSound();
            
            const indicator = document.getElementById('reloadIndicator');
            indicator.style.display = 'block';
            indicator.textContent = 'RELOADING...';
            
            setTimeout(() => {
                player.ammo = player.maxAmmo;
                player.reloading = false;
                indicator.style.display = 'none';
                updateHUD();
                playHitSound();
            }, reloadDuration);
        }
        
        function throwProjectile() {
            const now = Date.now();
            if (now - lastThrow < throwCooldown || player.ammo <= 0 || player.reloading) return;
            
            lastThrow = now;
            player.ammo--;
            playThrowSound();
            updateHUD();
            
            const projectile = createShurikenModel();
            projectile.position.copy(camera.position);
            
            const direction = new THREE.Vector3();
            camera.getWorldDirection(direction);
            
            projectile.userData = { velocity: direction.multiplyScalar(30), lifetime: 2000, birthTime: now, rotationSpeed: 0.5 };
            scene.add(projectile);
            projectiles.push(projectile);
            
            camera.rotation.x += 0.015;
        }
        
        function updatePlayer(delta) {
            let moveX = 0, moveZ = 0;
            
            // Desktop controls
            if (!isMobile) {
                const forward = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);
                forward.y = 0;
                forward.normalize();
                const right = new THREE.Vector3(1, 0, 0).applyQuaternion(camera.quaternion);
                right.y = 0;
                right.normalize();
                
                if (keys['KeyW']) moveZ -= 1;
                if (keys['KeyS']) moveZ += 1;
                if (keys['KeyA']) moveX -= 1;
                if (keys['KeyD']) moveX += 1;
                
                if (moveX !== 0 || moveZ !== 0) {
                    const direction = new THREE.Vector3(moveX, 0, moveZ).normalize();
                    const speed = keys['ShiftLeft'] ? player.sprintSpeed : player.speed;
                    player.x += direction.x * speed * delta;
                    player.z += direction.z * speed * delta;
                }
                
                if (keys['Space'] && !player.jumping) {
                    player.velocityY = 8;
                    player.jumping = true;
                }
            } else {
                // Mobile joystick
                if (joystick.active) {
                    const forward = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);
                    forward.y = 0;
                    forward.normalize();
                    const right = new THREE.Vector3(1, 0, 0).applyQuaternion(camera.quaternion);
                    right.y = 0;
                    right.normalize();
                    
                    const speed = player.speed;
                    player.x += (right.x * joystick.dx + forward.x * -joystick.dy) * speed * delta;
                    player.z += (right.z * joystick.dx + forward.z * -joystick.dy) * speed * delta;
                }
            }
            
            // Jump
            player.velocityY -= 20 * delta;
            player.y += player.velocityY * delta;
            
            if (player.y < 1.7) {
                player.y = 1.7;
                player.velocityY = 0;
                player.jumping = false;
            }
            
            camera.position.set(player.x, player.y, player.z);
        }
        
        function updateEnemies(delta, now) {
            enemies.forEach((enemy, index) => {
                if (!enemy.parent) return;
                
                const direction = new THREE.Vector3().subVectors(camera.position, enemy.position).normalize();
                direction.y = 0;
                
                enemy.position.add(direction.multiplyScalar(enemy.userData.speed * delta));
                enemy.lookAt(camera.position.x, enemy.position.y, enemy.position.z);
                
                if (enemy.userData.healthBar) {
                    enemy.userData.healthBar.container.position.set(enemy.position.x, 2.7, enemy.position.z);
                    enemy.userData.healthBar.fill.position.set(enemy.position.x, 2.7, enemy.position.z);
                    
                    const hp = enemy.userData.health / enemy.userData.maxHealth;
                    enemy.userData.healthBar.fill.scale.x = hp;
                    
                    if (hp > 0.5) enemy.userData.healthBar.fill.material.color.setHex(0x00ff00);
                    else if (hp > 0.25) enemy.userData.healthBar.fill.material.color.setHex(0xffff00);
                    else enemy.userData.healthBar.fill.material.color.setHex(0xff0000);
                }
                
                const distance = enemy.position.distanceTo(camera.position);
                if (distance < 2 && now - enemy.userData.lastAttack > 2000) {
                    player.health -= 10;
                    enemy.userData.lastAttack = now;
                    playEnemyAttackSound();
                    showDamageFeedback();
                    updateHUD();
                    
                    if (player.health <= 0) gameOver();
                }
            });
        }
        
        function showDamageFeedback() {
            const overlay = document.getElementById('damageOverlay');
            overlay.style.opacity = '1';
            setTimeout(() => { overlay.style.opacity = '0'; }, 300);
        }
        
        function updateProjectiles(delta, now) {
            projectiles.forEach((proj, index) => {
                if (!proj.parent) return;
                
                proj.position.add(proj.userData.velocity.clone().multiplyScalar(delta));
                
                if (proj.children.length > 0) {
                    proj.children.forEach(child => {
                        child.rotation.x += proj.userData.rotationSpeed;
                        child.rotation.z += proj.userData.rotationSpeed;
                    });
                }
                
                enemies.forEach((enemy, enemyIndex) => {
                    if (!enemy.parent) return;
                    
                    const dist = proj.position.distanceTo(enemy.position);
                    if (dist < 1) {
                        const hitOffset = proj.position.clone().sub(enemy.position);
                        const isHeadshot = hitOffset.y > 0.4;
                        
                        const baseDamage = 15;
                        const damageMultiplier = isHeadshot ? 2.5 : 1.5;
                        const totalDamage = baseDamage * damageMultiplier * player.combo;
                        
                        enemy.userData.health -= totalDamage;
                        playHitSound();
                        createHitEffect(proj.position, isHeadshot);
                        
                        scene.remove(proj);
                        projectiles.splice(index, 1);
                        
                        if (enemy.userData.health <= 0) {
                            scene.remove(enemy);
                            if (enemy.userData.healthBar) {
                                scene.remove(enemy.userData.healthBar.container);
                                scene.remove(enemy.userData.healthBar.fill);
                            }
                            enemies.splice(enemyIndex, 1);
                            
                            const points = isHeadshot ? 250 : 100;
                            player.score += points * player.combo;
                            player.combo = Math.min(5, player.combo + 1);
                            updateHUD();
                        }
                    }
                });
                
                if (now - proj.userData.birthTime > proj.userData.lifetime) {
                    scene.remove(proj);
                    projectiles.splice(index, 1);
                }
            });
        }
        
        function updateBonuses(delta) {
            bonuses.forEach((bonus, index) => {
                if (!bonus.parent) return;
                
                bonus.rotation.y += bonus.userData.rotationSpeed * delta;
                bonus.rotation.z += delta;
                
                const dist = bonus.position.distanceTo(camera.position);
                if (dist < 1.5) {
                    collectBonus(bonus.userData.type);
                    scene.remove(bonus);
                    bonuses.splice(index, 1);
                }
            });
        }
        
        function collectBonus(type) {
            switch(type) {
                case 'damage': player.combo = Math.min(5, player.combo + 2); player.score += 100; break;
                case 'speed': player.sprintSpeed = 12; setTimeout(() => player.sprintSpeed = 9, 5000); break;
                case 'health': player.health = Math.min(100, player.health + 25); break;
            }
            updateHUD();
        }
        
        function createHitEffect(pos, isHeadshot) {
            const count = isHeadshot ? 16 : 8;
            const color = isHeadshot ? 0xff0000 : 0xffff00;
            
            for (let i = 0; i < count; i++) {
                const p = new THREE.Mesh(
                    new THREE.SphereGeometry(isHeadshot ? 0.08 : 0.05, 4, 4),
                    new THREE.MeshBasicMaterial({ color, transparent: true })
                );
                p.position.copy(pos);
                p.userData = { vel: new THREE.Vector3((Math.random()-0.5)*8, (Math.random()-0.5)*8, (Math.random()-0.5)*8), birth: Date.now() };
                scene.add(p);
                setTimeout(() => scene.remove(p), 500);
            }
        }
        
        function updateHUD() {
            document.getElementById('score').textContent = player.score;
            document.getElementById('health').textContent = player.health;
            document.getElementById('ammo').textContent = player.ammo;
            document.getElementById('maxAmmo').textContent = player.maxAmmo;
            document.getElementById('combo').textContent = 'x' + player.combo;
            
            const ind = document.getElementById('reloadIndicator');
            if (player.ammo <= 5 && !player.reloading) {
                ind.style.display = 'block';
                ind.textContent = 'LOW AMMO - TAP RELOAD';
            } else if (!player.reloading) {
                ind.style.display = 'none';
            }
        }
        
        function gameOver() {
            alert('You have fallen, sensei. Score: ' + player.score);
            location.reload();
        }
        
        function animate() {
            requestAnimationFrame(animate);
            
            const delta = Math.min(clock.getDelta(), 0.1); // Cap delta for stability
            const now = Date.now();
            
            updatePlayer(delta);
            updateEnemies(delta, now);
            updateProjectiles(delta, now);
            updateBonuses(delta);
            
            renderer.render(scene, camera);
        }
        
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
        
        init();
    </script>
</body>
</html>
